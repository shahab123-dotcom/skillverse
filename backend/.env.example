# MongoDB
MONGO_URI=mongodb://localhost:27017/skillverse

# JWT (use the same secret in routes.js and paymentRoutes.js)
JWT_SECRET=your_jwt_secret

# Stripe test keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Escrow: hold duration before worker payout (default 1 day)
ESCROW_HOLD_DAYS=1
# Optional: override hold for quick testing (e.g. 2 = release after 2 minutes)
# ESCROW_HOLD_MINUTES=2
# How often the server checks for due releases (default 3600000 = 1 hour)
# ESCROW_CHECK_INTERVAL_MS=3600000

# Stripe Connect — connected account ID (acct_...) for worker payouts in test mode
# Create a test Express connected account in Stripe Dashboard → Connect
STRIPE_CONNECT_DESTINATION_ACCOUNT=acct_xxxxxxxx
